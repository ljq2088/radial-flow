Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"z", "\[Equal]", 
    RowBox[{"zc\:5904\:8fb9\:754c\:6761\:4ef6", 
     RowBox[{
      SubscriptBox["\[PartialD]", "z"], "R"}]}], "\[Equal]", 
    RowBox[{"\[Sigma]", "*", "R"}]}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"zc", "=", "z"}], "\[IndentingNewLine]", 
   RowBox[{"\[Sigma]", "*=", 
    FractionBox[
     RowBox[{"I", "*", "\[Omega]"}], 
     RowBox[{"1", "-", 
      RowBox[{"r0", "*", "z"}]}]]}], "\[IndentingNewLine]", 
   RowBox[{"Clear", "[", "z", "]"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"n", "=", "25"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"f", "[", "z_", "]"}], ":=", 
    RowBox[{"1", "-", 
     RowBox[{"r0", "*", "z"}]}]}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"x", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"Cos", "[", 
        FractionBox[
         RowBox[{"i", " ", "\[Pi]"}], 
         RowBox[{"n", "-", "1.0"}]], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", "0", ",", 
         RowBox[{"n", "-", "1"}]}], "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"c", "=", 
     RowBox[{"Table", "[", 
      RowBox[{"1.0", ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", "1", ",", "n"}], "}"}]}], "]"}]}], ";", 
    RowBox[{
     RowBox[{"c", "[", 
      RowBox[{"[", "1", "]"}], "]"}], "=", "2.0"}], ";", 
    RowBox[{
     RowBox[{"c", "[", 
      RowBox[{"[", "n", "]"}], "]"}], "=", "2.0"}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"d", "=", 
     RowBox[{
      FractionBox["2", "zc"], 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"i", "\[NotEqual]", "j"}], ",", 
          RowBox[{
           FractionBox[
            RowBox[{"c", "[", 
             RowBox[{"[", "i", "]"}], "]"}], 
            RowBox[{"c", "[", 
             RowBox[{"[", "j", "]"}], "]"}]], 
           FractionBox[
            SuperscriptBox[
             RowBox[{"(", 
              RowBox[{"-", "1"}], ")"}], 
             RowBox[{"i", "+", "j"}]], 
            RowBox[{
             RowBox[{"x", "[", 
              RowBox[{"[", "i", "]"}], "]"}], "-", 
             RowBox[{"x", "[", 
              RowBox[{"[", "j", "]"}], "]"}]}]]}], ",", "0"}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"i", ",", "1", ",", "n"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"j", ",", "1", ",", "n"}], "}"}]}], "]"}]}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"d", "-=", 
     RowBox[{"DiagonalMatrix", "[", 
      RowBox[{"Total", "[", 
       RowBox[{"d", ",", 
        RowBox[{"{", "2", "}"}]}], "]"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"z", "=", 
     RowBox[{
      FractionBox[
       RowBox[{"1", "+", "x"}], "2"], "zc"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"fz", "=", 
     RowBox[{"f", "[", "z", "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"lop", "=", 
     RowBox[{
      RowBox[{"d", ".", 
       RowBox[{"DiagonalMatrix", "[", 
        RowBox[{
         SuperscriptBox["z", "2"], "fz"}], "]"}], ".", "d"}], "+", 
      RowBox[{"2", "I", "*", "\[Omega]", 
       RowBox[{"(", 
        RowBox[{"1", "-", 
         RowBox[{
          SuperscriptBox["r0", "2"], 
          SuperscriptBox["z", "2"]}]}], ")"}], 
       RowBox[{"(", 
        RowBox[{"-", "d"}], ")"}]}], "+", 
      RowBox[{"DiagonalMatrix", "[", 
       RowBox[{
        RowBox[{"2", "I", "*", "\[Omega]", "*", 
         SuperscriptBox["r0", "2"], "z"}], "-", 
        RowBox[{"r0", "*", "z"}], "+", 
        RowBox[{
         FractionBox[
          RowBox[{
           SuperscriptBox["\[Omega]", "2"], 
           SuperscriptBox["r0", "2"]}], "fz"], 
         RowBox[{"(", 
          RowBox[{"2", "-", 
           RowBox[{
            SuperscriptBox["r0", "2"], 
            SuperscriptBox["z", "2"]}]}], ")"}]}], "-", 
