  RowBox[{
   RowBox[{"Clear", "[", "\"\<Global`*\>\"", "]"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"r0", "=", "2.0"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[Omega]", "=", "0.2"}], ";", 
    RowBox[{"l", "=", "0"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"evz", "[", 
     RowBox[{"\[Sigma]_", ",", "z_"}], "]"}], ":=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"z", "\[Equal]", 
         SuperscriptBox["r0", 
          RowBox[{"-", "1"}]]}], ",", 
        FractionBox[
         RowBox[{
          RowBox[{"4", 
           SuperscriptBox["\[Omega]", "2"], 
           SuperscriptBox["r0", "4"]}], "-", 
          RowBox[{"l", 
           RowBox[{"(", 
            RowBox[{"l", "+", "1"}], ")"}], "*", 
           SuperscriptBox["r0", "2"]}]}], 
         RowBox[{
          RowBox[{
           RowBox[{"-", "I"}], "*", "\[Omega]"}], "-", 
          RowBox[{"2", 
           SuperscriptBox["\[Omega]", "2"], "r0"}]}]], ",", 
        RowBox[{
         FractionBox[
          RowBox[{
           RowBox[{
            RowBox[{"-", 
             SuperscriptBox["\[Omega]", "2"]}], 
            RowBox[{
             SuperscriptBox["z", 
              RowBox[{"-", "2"}]], "/", 
             RowBox[{"(", 
              RowBox[{"1", "-", 
               RowBox[{"r0", "*", "z"}]}], ")"}]}]}], "+", 
           RowBox[{"l", 
            RowBox[{"(", 
             RowBox[{"l", "+", "1"}], ")"}]}]}], 
          RowBox[{"I", "*", "\[Omega]", "*", 
           SuperscriptBox["z", "2"]}]], "-", 
         RowBox[{
          FractionBox[
           RowBox[{"I", "*", "\[Omega]"}], 
           RowBox[{"1", "-", 
            RowBox[{"r0", "*", "z"}]}]], 
          SuperscriptBox["\[Sigma]", "2"]}]}]}], "]"}], ",", "1"}], "}"}]}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"z", "=", 
     SuperscriptBox["r0", 
      RowBox[{"-", "1"}]]}], ";", 
    RowBox[{"\[Sigma]", "=", 
     SuperscriptBox["r0", "2"]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"st", "=", 
     RowBox[{"-", "0.00025"}]}], ";", 
    RowBox[{"times", "=", "1000"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"snaps", "=", 
     RowBox[{"{", "}"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"Monitor", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"Label", "[", "\"\<ev\>\"", "]"}], ";", 
      RowBox[{"\[CapitalPsi]", "=", 
       RowBox[{"{", 
        RowBox[{"\[Sigma]", ",", "z"}], "}"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"R1", "=", 
       RowBox[{"Apply", "[", 
        RowBox[{"evz", ",", "\[CapitalPsi]"}], "]"}]}], ";", 
      RowBox[{"R2", "=", 
       RowBox[{"Apply", "[", 
        RowBox[{"evz", ",", 
         RowBox[{"\[CapitalPsi]", "+", 
          RowBox[{
           FractionBox["st", "2"], "R1"}]}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"R3", "=", 
       RowBox[{"Apply", "[", 
        RowBox[{"evz", ",", 
         RowBox[{"\[CapitalPsi]", "+", 
          RowBox[{
           FractionBox["st", "2"], "R2"}]}]}], "]"}]}], ";", 
      RowBox[{"R4", "=", 
       RowBox[{"Apply", "[", 
        RowBox[{"evz", ",", 
         RowBox[{"\[CapitalPsi]", "+", 
          RowBox[{"st", "*", "R3"}]}]}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"\[Sigma]", ",", "z"}], "}"}], "+=", 
       RowBox[{
        FractionBox["st", "6"], 
        RowBox[{"(", 
         RowBox[{"R1", "+", 
          RowBox[{"2", "R2"}], "+", 
          RowBox[{"2", "R3"}], "+", "R4"}], ")"}]}]}], ";", 
      RowBox[{"times", "=", 
       RowBox[{"times", "-", "1"}]}], ";", 
      RowBox[{"AppendTo", "[", 
       RowBox[{"snaps", ",", "\[CapitalPsi]"}], "]"}], ";", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"times", ">", "0"}], ",", 
        RowBox[{"Goto", "[", "\"\<ev\>\"", "]"}]}], "]"}]}], ",", "times"}], 
    "]"}], "\[IndentingNewLine]", 
