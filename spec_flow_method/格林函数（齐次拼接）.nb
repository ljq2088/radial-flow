           FractionBox["st", "2"], "R1"}]}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"R3", "=", 
       RowBox[{"Apply", "[", 
        RowBox[{"evz", ",", 
         RowBox[{"\[CapitalPsi]", "+", 
          RowBox[{
           FractionBox["st", "2"], "R2"}]}]}], "]"}]}], ";", 
      RowBox[{"R4", "=", 
       RowBox[{"Apply", "[", 
        RowBox[{"evz", ",", 
         RowBox[{"\[CapitalPsi]", "+", 
          RowBox[{"st", "*", "R3"}]}]}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"\[Sigma]", ",", "r"}], "}"}], "+=", 
       RowBox[{
        FractionBox["st", "6"], 
        RowBox[{"(", 
         RowBox[{"R1", "+", 
          RowBox[{"2", "R2"}], "+", 
          RowBox[{"2", "R3"}], "+", "R4"}], ")"}]}]}], ";", 
      RowBox[{"times", "=", 
       RowBox[{"times", "-", "1"}]}], ";", 
      RowBox[{"AppendTo", "[", 
       RowBox[{"snaps", ",", "\[CapitalPsi]"}], "]"}], ";", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"times", ">", "0"}], ",", 
        RowBox[{"Goto", "[", "\"\<ev\>\"", "]"}]}], "]"}]}], ",", "times"}], 
    "]"}], "\[IndentingNewLine]", 
