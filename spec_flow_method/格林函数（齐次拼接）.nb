   RowBox[{
    RowBox[{"st", "=", "0.00002"}], ";", 
    RowBox[{"times", "=", "50000"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"snaps", "=", 
     RowBox[{"{", "}"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"Monitor", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"Label", "[", "\"\<ev\>\"", "]"}], ";", 
      RowBox[{"\[CapitalPsi]", "=", 
       RowBox[{"{", 
        RowBox[{"\[Sigma]", ",", "r"}], "}"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"R1", "=", 
       RowBox[{"Apply", "[", 
        RowBox[{"evz", ",", "\[CapitalPsi]"}], "]"}]}], ";", 
      RowBox[{"R2", "=", 
