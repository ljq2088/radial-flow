    RowBox[{"l", "=", "1"}], ";", 
    RowBox[{"(*", 
     RowBox[{"\:82e5l", "=", 
      RowBox[{"0", "\:884c\:4e3a\:66f4\:5dee"}]}], "*)"}], 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"evz", "[", 
      RowBox[{"\[Sigma]_", ",", "r_"}], "]"}], ":=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"r", "\[Equal]", "r0"}], ",", 
         FractionBox[
          RowBox[{
           RowBox[{"4", 
            SuperscriptBox["\[Omega]", "2"], 
            SuperscriptBox["r0", "2"]}], "-", 
           RowBox[{"l", 
            RowBox[{"(", 
             RowBox[{"l", "+", "1"}], ")"}]}]}], 
          RowBox[{
           RowBox[{"I", "*", "\[Omega]"}], "+", 
           RowBox[{"2", 
            SuperscriptBox["\[Omega]", "2"], "r0"}]}]], ",", 
         RowBox[{
          RowBox[{"-", 
           FractionBox[
            RowBox[{
             RowBox[{
              RowBox[{"-", 
               SuperscriptBox["\[Omega]", "2"]}], 
              RowBox[{
               SuperscriptBox["r", "2"], "/", 
               RowBox[{"(", 
                RowBox[{"1", "-", 
                 FractionBox["r0", "r"]}], ")"}]}]}], "+", 
             RowBox[{"l", 
              RowBox[{"(", 
               RowBox[{"l", "+", "1"}], ")"}]}]}], 
            RowBox[{"I", "*", "\[Omega]"}]]}], "+", 
          RowBox[{
           FractionBox[
            RowBox[{"I", "*", "\[Omega]"}], 
            RowBox[{
             SuperscriptBox["r", "2"], "-", 
             RowBox[{"r0", "*", "r"}]}]], 
           SuperscriptBox["\[Sigma]", "2"]}]}]}], "]"}], ",", "1"}], 
      "}"}]}]}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"r", "=", "r0"}], ";", 
    RowBox[{"\[Sigma]", "=", 
