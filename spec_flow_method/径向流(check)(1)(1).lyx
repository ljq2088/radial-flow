\begin_layout Plain Layout
Relation between different definitions of 
\begin_inset Formula $\sigma$
\end_inset

:
\begin_inset Formula 
\[
\tilde{\sigma}=\frac{f\partial_{r}R+i\omega R+\frac{f}{r}R}{f\partial_{r}R-i\omega R+\frac{f}{r}R},\qquad\sigma=\frac{f\partial_{r}R+i\omega R}{f\partial_{r}R-i\omega R}
\]

\end_inset


\begin_inset Formula 
\[
\frac{1}{\tilde{\sigma}-1}=\frac{f\partial_{r}R-i\omega R+\frac{f}{r}R}{2i\omega R},\qquad\frac{1}{\sigma-1}=\frac{f\partial_{r}R-i\omega R}{2i\omega R}
\]

\end_inset


\begin_inset Formula 
\[
\Longrightarrow\frac{1}{\tilde{\sigma}-1}-\frac{1}{\sigma-1}=\frac{f}{2i\omega r}
\]

\end_inset


\begin_inset Formula 
\[
\frac{1}{\tilde{\sigma}-1}=\frac{1}{\sigma-1}+\frac{f}{2i\omega r}=\frac{1}{\sigma-1}(1-\frac{f}{2i\omega r}+\frac{f}{2i\omega r}\sigma)
\]

\end_inset


\begin_inset Formula 
\[
\tilde{\sigma}=\frac{\sigma-1}{1-\frac{f}{2i\omega r}+\frac{f}{2i\omega r}\sigma}+1=\frac{(1+\frac{f}{2i\omega r})\sigma-\frac{f}{2i\omega r}}{\frac{f}{2i\omega r}\sigma+(1-\frac{f}{2i\omega r})}
\]

\end_inset

Generally,
\begin_inset Formula 
\[
\sigma^{\prime}=q+s\sigma+w\sigma^{2}=\left(\begin{array}{cc}
1 & -\sigma\end{array}\right)\left(\begin{array}{cc}
q & -\frac{s}{2}\\
-\frac{s}{2} & w
\end{array}\right)\left(\begin{array}{c}
1\\
-\sigma
\end{array}\right),\qquad\tau=\frac{a\sigma+b}{c\sigma+d}\Longrightarrow
\]

\end_inset


\begin_inset Formula 
\begin{eqnarray*}
\tau^{\prime} & = & \frac{a^{\prime}\sigma+aq+as\sigma+aw\sigma^{2}+b^{\prime}}{c\sigma+d}-\frac{(a\sigma+b)(c^{\prime}\sigma+cq+cs\sigma+cw\sigma^{2}+d^{\prime})}{(c\sigma+d)^{2}}\\
 & = & \frac{a^{\prime}\sigma+aq+as\sigma+w(a\sigma+b)\sigma-wb\sigma+b^{\prime}}{c\sigma+d}-\frac{(a\sigma+b)(c^{\prime}\sigma+cq+cs\sigma+w[c\sigma+d]\sigma-wd\sigma+d^{\prime})}{(c\sigma+d)^{2}}\\
 & = & \frac{(a^{\prime}+as-wb)\sigma+(aq+b^{\prime})}{c\sigma+d}-\frac{(a\sigma+b)([c^{\prime}+cs-wd]\sigma+[cq+d^{\prime}])}{(c\sigma+d)^{2}}\\
 & = & \frac{(a^{\prime}+as-wb)[\frac{d}{\Delta}(a\sigma+b)-\frac{b}{\Delta}(c\sigma+d)]+(aq+b^{\prime})[-\frac{c}{\Delta}(a\sigma+b)+\frac{a}{\Delta}(c\sigma+d)]}{c\sigma+d}-\frac{(a\sigma+b)([c^{\prime}+cs-wd]\sigma+[cq+d^{\prime}])}{(c\sigma+d)^{2}}\\
 & = & \frac{a}{\Delta}(aq+b^{\prime})-\frac{b}{\Delta}(a^{\prime}+as-wb)+\frac{d(a^{\prime}+as-wb)-c(aq+b^{\prime})}{\Delta}\tau-\frac{(a\sigma+b)([c^{\prime}+cs-wd][\frac{d}{\Delta}(a\sigma+b)-\frac{b}{\Delta}(c\sigma+d)]+[cq+d^{\prime}][-\frac{c}{\Delta}(a\sigma+b)+\frac{a}{\Delta}(c\sigma+d)])}{(c\sigma+d)^{2}}\\
 & = & \frac{a}{\Delta}(aq+b^{\prime})-\frac{b}{\Delta}(a^{\prime}+as-wb)+\frac{d(a^{\prime}+as-wb)-c(aq+b^{\prime})}{\Delta}\tau-\frac{-b[c^{\prime}+cs-wd]+a[cq+d^{\prime}]}{\Delta}\tau-\frac{d[c^{\prime}+cs-wd]-c[cq+d^{\prime}]}{\Delta}\tau^{2}\\
 & = & \frac{\vec{N}\cdot\vec{N}+W[a,b]}{\Delta}+\frac{W[d,a]-W[c,b]-2\vec{N}\cdot\vec{D}}{\Delta}\tau+\frac{\vec{D}\cdot\vec{D}+W[c,d]}{\Delta}\tau^{2},\qquad\Delta:=ad-bc
\end{eqnarray*}

\end_inset


\begin_inset Box Frameless
