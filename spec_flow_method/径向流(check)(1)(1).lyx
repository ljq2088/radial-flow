\begin_layout Plain Layout
\begin_inset Formula 
\[
\sigma=\frac{d}{\Delta}(a\sigma+b)-\frac{b}{\Delta}(c\sigma+d),\qquad1=-\frac{c}{\Delta}(a\sigma+b)+\frac{a}{\Delta}(c\sigma+d)
\]

\end_inset


\begin_inset Formula 
\[
\sigma=\frac{eR^{\prime}+fR}{gR^{\prime}+hR}\Longrightarrow\tau=\frac{iR^{\prime}+jR}{kR^{\prime}+lR},\qquad\left(\begin{array}{cc}
i & j\\
k & l
\end{array}\right)=\left(\begin{array}{cc}
a & b\\
c & d
\end{array}\right)\left(\begin{array}{cc}
e & f\\
g & h
\end{array}\right)
\]

\end_inset


\end_layout

\end_inset


\begin_inset Formula 
\[
\vec{N}:=(a,b),\qquad\vec{D}:=(c,d),\qquad\vec{A}\cdot\vec{B}:=A_{1}qB_{1}+A_{2}wB_{2}-A_{1}\frac{s}{2}B_{2}-A_{2}\frac{s}{2}B_{1},\qquad W[a,b]:=b^{\prime}a-a^{\prime}b
\]

\end_inset

Actually,
\begin_inset Formula 
\[
\tau^{\prime}=\frac{\vec{N}\bullet\vec{N}}{\Delta}-2\frac{\vec{N}\bullet\vec{D}}{\Delta}\tau+\frac{\vec{D}\bullet\vec{D}}{\Delta}\tau^{2},\qquad\vec{A}\bullet\vec{B}:=\vec{A}\cdot\vec{B}+\frac{1}{2}W[A_{1},B_{2}]-\frac{1}{2}W[A_{2},B_{1}]=\left(\begin{array}{cc}
A_{1} & A_{2}\end{array}\right)\left(\begin{array}{cc}
q & \frac{\mathcal{W}(=\overrightarrow{\partial}-\overleftarrow{\partial})}{2}-\frac{s}{2}\\
\frac{\mathcal{W}^{T}(=-\mathcal{W})}{2}-\frac{s}{2} & w
\end{array}\right)\left(\begin{array}{c}
B_{1}\\
B_{2}
\end{array}\right)
\]

\end_inset

with 
\begin_inset Formula $a\mathcal{W}b:=W[a,b]$
\end_inset

 a skew-symmetric form.
 Further,
\begin_inset Formula 
\[
\tau^{\prime}=\frac{1}{\Delta}\left(\begin{array}{cc}
1 & -\tau\end{array}\right)C\left(\begin{array}{cc}
q & \frac{\mathcal{W}}{2}-\frac{s}{2}\\
\frac{\mathcal{W}^{T}}{2}-\frac{s}{2} & w
\end{array}\right)C^{T}\left(\begin{array}{c}
1\\
-\tau
\end{array}\right),\qquad C=\left(\begin{array}{cc}
a & b\\
c & d
\end{array}\right)
\]

\end_inset

Note that
\begin_inset Formula 
\[
C^{T}\left(\begin{array}{c}
1\\
-\tau
\end{array}\right)=\left(\begin{array}{c}
a-c\frac{a\sigma+b}{c\sigma+d}\\
b-d\frac{a\sigma+b}{c\sigma+d}
\end{array}\right)=\frac{\Delta}{c\sigma+d}\left(\begin{array}{c}
1\\
-\sigma
\end{array}\right)
\]

\end_inset

and
\begin_inset Formula 
\[
\sigma=\frac{d\tau-b}{-c\tau+a},\qquad c\sigma+d=\frac{cd\tau-cb}{-c\tau+a}+d=\frac{\Delta}{-c\tau+a}\Longrightarrow
\]

\end_inset


\begin_inset Formula 
\begin{eqnarray*}
\tau^{\prime} & = & \frac{a\sigma^{\prime}+a^{\prime}\sigma+b^{\prime}}{c\sigma+d}-\frac{(a\sigma+b)(c\sigma^{\prime}+c^{\prime}\sigma+d^{\prime})}{(c\sigma+d)^{2}}=\frac{a^{\prime}\sigma+b^{\prime}}{c\sigma+d}+\frac{\Delta\sigma^{\prime}}{(c\sigma+d)^{2}}-\frac{(a\sigma+b)(c^{\prime}\sigma+d^{\prime})}{(c\sigma+d)^{2}}\\
 & = & \frac{\Delta\sigma^{\prime}}{(c\sigma+d)^{2}}+\frac{W[c,a]\sigma^{2}+(W[c,b]+W[d,a])\sigma+W[d,b]}{(c\sigma+d)^{2}}\\
 & = & \Delta^{-1}(-c\tau+a)^{2}[q+s\frac{d\tau-b}{-c\tau+a}+w(\frac{d\tau-b}{-c\tau+a})^{2}]+\Delta^{-2}(-c\tau+a)^{2}(W[c,a](\frac{d\tau-b}{-c\tau+a})^{2}+(W[c,b]+W[d,a])\frac{d\tau-b}{-c\tau+a}+W[d,b])\\
 & = & \Delta^{-1}[q(-c\tau+a)^{2}+s(d\tau-b)(-c\tau+a)+w(d\tau-b)^{2}]+\Delta^{-2}(W[c,a][d\tau-b]^{2}+(W[c,b]+W[d,a])[d\tau-b][-c\tau+a]+W[d,b][-c\tau+a]^{2})\\
 & = & \cdots
\end{eqnarray*}

\end_inset


\begin_inset Formula 
\begin{eqnarray*}
 &  & d^{2}(ca^{\prime}-ac^{\prime})-cd(cb^{\prime}-bc^{\prime}+da^{\prime}-ad^{\prime})+c^{2}(db^{\prime}-bd^{\prime})\\
 & = & d^{2}(-ac^{\prime})-cd(-bc^{\prime}-ad^{\prime})+c^{2}(-bd^{\prime})=\Delta W[c,d]
\end{eqnarray*}

\end_inset


