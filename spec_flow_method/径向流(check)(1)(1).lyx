\begin_layout Plain Layout
\begin_inset Formula 
\[
R\sim Ae^{i\omega r}+Be^{-i\omega r}\Longrightarrow J=g^{rr}\partial_{r}R\sim i\omega(Ae^{i\omega r}-Be^{-i\omega r})
\]

\end_inset


\begin_inset Formula 
\[
\sigma=\frac{J+i\omega R}{J-i\omega R}\sim-\frac{A}{B}e^{2i\omega r}
\]

\end_inset


\begin_inset Formula 
\begin{eqnarray*}
\partial_{r}\sigma & = & \frac{-\frac{2}{r}J+g^{tt}\omega^{2}R+r^{-2}l(l+1)R+i\omega R^{\prime}}{J-i\omega R}-\frac{J+i\omega R}{(J-i\omega R)^{2}}[-\frac{2}{r}J+g^{tt}\omega^{2}R+r^{-2}l(l+1)R-i\omega R^{\prime}]\\
 & = & \frac{(i\omega g_{rr}-\frac{2}{r})\frac{J+i\omega R+J-i\omega R}{2}+[g^{tt}\omega^{2}+r^{-2}l(l+1)]\frac{J+i\omega R-(J-i\omega R)}{2i\omega}}{J-i\omega R}-\frac{J+i\omega R}{(J-i\omega R)^{2}}[(-i\omega g_{rr}-\frac{2}{r})\frac{J+i\omega R+J-i\omega R}{2}+[g^{tt}\omega^{2}+r^{-2}l(l+1)]\frac{J+i\omega R-(J-i\omega R)}{2i\omega}]\\
 & = & \frac{i\omega}{2}g_{rr}-\frac{1}{r}-\frac{g^{tt}\omega^{2}+r^{-2}l(l+1)}{2i\omega}+[\frac{i\omega}{2}g_{rr}-\frac{1}{r}+\frac{g^{tt}\omega^{2}+r^{-2}l(l+1)}{2i\omega}]\sigma-[-\frac{i\omega}{2}g_{rr}-\frac{1}{r}-\frac{g^{tt}\omega^{2}+r^{-2}l(l+1)}{2i\omega}]\sigma-[-\frac{i\omega}{2}g_{rr}-\frac{1}{r}+\frac{g^{tt}\omega^{2}+r^{-2}l(l+1)}{2i\omega}]\sigma^{2}\\
 & = & \frac{i\omega}{2}g_{rr}-\frac{1}{r}-\frac{g^{tt}\omega^{2}+r^{-2}l(l+1)}{2i\omega}+[i\omega g_{rr}+\frac{g^{tt}\omega^{2}+r^{-2}l(l+1)}{i\omega}]\sigma-[-\frac{i\omega}{2}g_{rr}-\frac{1}{r}+\frac{g^{tt}\omega^{2}+r^{-2}l(l+1)}{2i\omega}]\sigma^{2}\\
 & = & -\frac{1}{r}-\frac{r^{-2}l(l+1)}{2i\omega}+[2i\omega f^{-1}+\frac{r^{-2}l(l+1)}{i\omega}]\sigma-[-\frac{1}{r}+\frac{r^{-2}l(l+1)}{2i\omega}]\sigma^{2}
\end{eqnarray*}

\end_inset


\begin_inset Formula 
\[
\partial_{r}\sigma\hat{=}-\frac{1}{r}-\frac{r^{-2}l(l+1)}{2i\omega}+2i\omega\frac{\sigma^{\prime}}{f^{\prime}}+\frac{r^{-2}l(l+1)}{i\omega}\sigma-[-\frac{1}{r}+\frac{r^{-2}l(l+1)}{2i\omega}]\sigma^{2}
\]

\end_inset


\begin_inset Formula 
\[
\Longrightarrow\sigma_{0}=0,\qquad\sigma_{0}^{\prime}=\frac{-f_{0}^{\prime}-\frac{l(l+1)}{2i\omega r_{0}}f_{0}^{\prime}}{r_{0}f_{0}^{\prime}-2i\omega r_{0}}
\]

\end_inset


