\begin_layout Plain Layout
\begin_inset Formula 
\[
\sigma e^{-2i\omega(r+r_{0}\ln\frac{r}{r_{0}})}=(\sigma_{0}+\frac{c}{r^{2}}e^{2i\omega(r+r_{0}\ln\frac{r}{r_{0}})}+\frac{d}{r^{2}}e^{-2i\omega(r+r_{0}\ln\frac{r}{r_{0}})})\frac{1+\frac{r_{0}}{r}-\frac{1}{r}[\frac{l(l+1)}{2i\omega}+i\omega r_{0}^{2}]}{1+\frac{r_{0}}{r}-\frac{1}{r}[\frac{l(l+1)}{-2i\omega}-i\omega r_{0}^{2}]}
\]

\end_inset


\end_layout

\end_inset


\begin_inset Formula 
\begin{eqnarray*}
\partial_{r}\sigma & = & \frac{-\frac{2}{r}fR^{\prime}+g^{tt}\omega^{2}R+r^{-2}l(l+1)R+(r^{-1}f)^{\prime}R+r^{-1}fR^{\prime}+i\omega R^{\prime}}{f\partial_{r}R+\frac{f}{r}R-i\omega R}-\frac{f\partial_{r}R+\frac{f}{r}R+i\omega R}{(f\partial_{r}R+\frac{f}{r}R-i\omega R)^{2}}[-\frac{2}{r}fR^{\prime}+g^{tt}\omega^{2}R+r^{-2}l(l+1)R+(r^{-1}f)^{\prime}R+r^{-1}fR^{\prime}-i\omega R^{\prime}]\\
 & = & \frac{(i\omega g_{rr}-\frac{1}{r})(J-\frac{f}{r}R)+[g^{tt}\omega^{2}+r^{-2}l(l+1)+(r^{-1}f)^{\prime}]R}{J-i\omega R}-\frac{J+i\omega R}{(J-i\omega R)^{2}}[(-i\omega g_{rr}-\frac{1}{r})(J-\frac{f}{r}R)+[g^{tt}\omega^{2}+r^{-2}l(l+1)+(r^{-1}f)^{\prime}]R]\\
 & = & \frac{(i\omega g_{rr}-\frac{1}{r})\frac{J+i\omega R+J-i\omega R}{2}+[-\frac{i\omega}{r}+g^{tt}\omega^{2}+r^{-2}l(l+1)+r^{-1}f^{\prime}]\frac{J+i\omega R-(J-i\omega R)}{2i\omega}}{J-i\omega R}-\frac{J+i\omega R}{(J-i\omega R)^{2}}[(-i\omega g_{rr}-\frac{1}{r})\frac{J+i\omega R+J-i\omega R}{2}+[\frac{i\omega}{r}+g^{tt}\omega^{2}+r^{-2}l(l+1)+r^{-1}f^{\prime}]\frac{J+i\omega R-(J-i\omega R)}{2i\omega}]\\
 & = & \frac{i\omega}{2}g_{rr}-\frac{1}{2r}-\frac{-\frac{i\omega}{r}+g^{tt}\omega^{2}+r^{-2}l(l+1)+r^{-1}f^{\prime}}{2i\omega}+[\frac{i\omega}{2}g_{rr}-\frac{1}{2r}+\frac{\frac{i\omega}{r}+g^{tt}\omega^{2}+r^{-2}l(l+1)+r^{-1}f^{\prime}}{2i\omega}]\sigma-[-\frac{i\omega}{2}g_{rr}-\frac{1}{2r}-\frac{-\frac{i\omega}{r}+g^{tt}\omega^{2}+r^{-2}l(l+1)+r^{-1}f^{\prime}}{2i\omega}]\sigma-[-\frac{i\omega}{2}g_{rr}-\frac{1}{2r}+\frac{\frac{i\omega}{r}+g^{tt}\omega^{2}+r^{-2}l(l+1)+r^{-1}f^{\prime}}{2i\omega}]\sigma^{2}\\
 & = & \frac{i\omega}{2}g_{rr}-\frac{g^{tt}\omega^{2}+r^{-2}l(l+1)+r^{-1}f^{\prime}}{2i\omega}+[i\omega g_{rr}+\frac{g^{tt}\omega^{2}+r^{-2}l(l+1)+r^{-1}f^{\prime}}{i\omega}]\sigma-[-\frac{i\omega}{2}g_{rr}+\frac{g^{tt}\omega^{2}+r^{-2}l(l+1)+r^{-1}f^{\prime}}{2i\omega}]\sigma^{2}\\
 & = & -\frac{r^{-2}l(l+1)+r^{-1}f^{\prime}}{2i\omega}+[2i\omega f^{-1}+\frac{r^{-2}l(l+1)+r^{-1}f^{\prime}}{i\omega}]\sigma-\frac{r^{-2}l(l+1)+r^{-1}f^{\prime}}{2i\omega}\sigma^{2}
\end{eqnarray*}

\end_inset


\begin_inset Formula 
\[
\partial_{r}\sigma\hat{=}-\frac{r^{-2}l(l+1)+r^{-1}f^{\prime}}{2i\omega}+2i\omega\frac{\sigma^{\prime}}{f^{\prime}}+\frac{r^{-2}l(l+1)+r^{-1}f^{\prime}}{i\omega}\sigma-\frac{r^{-2}l(l+1)+r^{-1}f^{\prime}}{2i\omega}\sigma^{2}
\]

\end_inset


\begin_inset Formula 
\[
\Longrightarrow\sigma_{0}=0,\qquad\sigma_{0}^{\prime}=\frac{-\frac{l(l+1)+r_{0}f_{0}^{\prime}}{2i\omega r_{0}}f_{0}^{\prime}}{r_{0}f_{0}^{\prime}-2i\omega r_{0}}
\]

\end_inset


\end_layout

\end_inset


