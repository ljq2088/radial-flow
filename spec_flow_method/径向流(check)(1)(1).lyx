\begin_layout Plain Layout
\begin_inset Formula 
\[
R\sim(A_{0}+\frac{\tilde{A}_{1}}{r})r^{-1}e^{i\omega r_{*}}+(B_{0}+\frac{\tilde{B}_{1}}{r})r^{-1}e^{-i\omega r_{*}},\qquad r_{*}=r+r_{0}\ln(\frac{r}{r_{0}}-1)
\]

\end_inset


\begin_inset Formula 
\begin{eqnarray*}
\Longrightarrow R & \sim & (A_{0}+\frac{\tilde{A}_{1}}{r})r^{-1}(\frac{r}{r_{0}}-1)^{i\omega r_{0}}e^{i\omega r}+(B_{0}+\frac{\tilde{B}_{1}}{r})r^{-1}(\frac{r}{r_{0}}-1)^{-i\omega r_{0}}e^{-i\omega r}\\
 & \sim & (1+\frac{1}{r}\frac{A_{1}}{A_{0}})A_{0}r^{a}e^{i\omega r}+(1+\frac{1}{r}\frac{B_{1}}{B_{0}})B_{0}r^{b}e^{-i\omega r}\Longrightarrow
\end{eqnarray*}

\end_inset


\begin_inset Formula 
\begin{eqnarray*}
f\partial_{r}R & \sim & (1-\frac{r_{0}}{r})(i\omega+\frac{a}{r}+\frac{i\omega}{r}\frac{A_{1}}{A_{0}})A_{0}r^{a}e^{i\omega r}+(1-\frac{r_{0}}{r})(-i\omega+\frac{b}{r}-\frac{i\omega}{r}\frac{B_{1}}{B_{0}})B_{0}r^{b}e^{-i\omega r}\\
 & \sim & (i\omega-\frac{1}{r}+\frac{i\omega}{r}\frac{A_{1}}{A_{0}})A_{0}r^{a}e^{i\omega r}+(-i\omega-\frac{1}{r}-\frac{i\omega}{r}\frac{B_{1}}{B_{0}})B_{0}r^{b}e^{-i\omega r}
\end{eqnarray*}

\end_inset


\begin_inset Formula 
\[
J=\frac{f}{r}\partial_{r}(rR)=f\partial_{r}R+\frac{f}{r}R\sim(i\omega+\frac{i\omega}{r}\frac{A_{1}}{A_{0}})A_{0}r^{a}e^{i\omega r}+(-i\omega-\frac{i\omega}{r}\frac{B_{1}}{B_{0}})B_{0}r^{b}e^{-i\omega r}
\]

\end_inset


\begin_inset Formula 
\[
\sigma=\frac{J+i\omega R}{J-i\omega R}=\frac{f\partial_{r}R+\frac{f}{r}R+i\omega R}{f\partial_{r}R+\frac{f}{r}R-i\omega R}\sim-\frac{A_{0}}{B_{0}}\frac{1+\frac{1}{r}\frac{A_{1}}{A_{0}}}{1+\frac{1}{r}\frac{B_{1}}{B_{0}}}e^{2i\omega(r+r_{0}\ln\frac{r}{r_{0}})}
\]

\end_inset


