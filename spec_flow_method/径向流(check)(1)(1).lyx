i\omega(1-\frac{r_{0}^{2}}{r^{2}})-\frac{s}{2} & we^{2i\omega(r+r_{0}\ln\frac{r}{r_{0}})}
\end{array}\right)\left(\begin{array}{c}
1\\
-\tau
\end{array}\right)
\]

\end_inset


\begin_inset Formula 
\[
C=\left(\begin{array}{cc}
