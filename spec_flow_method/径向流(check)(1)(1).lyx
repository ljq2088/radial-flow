\Longrightarrow1+\frac{1}{r}\frac{A_{1}}{A_{0}}=1+{\color{red}\frac{r_{0}}{r}}-\frac{1}{r}[\frac{l(l+1)}{2i\omega}+i\omega r_{0}^{2}],\qquad1+\frac{1}{r}\frac{B_{1}}{B_{0}}=1+{\color{red}\frac{r_{0}}{r}}-\frac{1}{r}[\frac{l(l+1)}{-2i\omega}-i\omega r_{0}^{2}]
