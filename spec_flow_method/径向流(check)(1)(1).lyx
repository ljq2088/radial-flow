\end{array}\right)
\]

\end_inset


\begin_inset Formula 
\[
\left(\begin{array}{cc}
e & f\\
g & h
\end{array}\right)\left(\begin{array}{cc}
0 & \frac{\mathcal{W}}{2}\\
\frac{\mathcal{W}^{T}}{2} & 0
\end{array}\right)\left(\begin{array}{cc}
e & g\\
f & h
\end{array}\right)=(-W[h,e]+W[g,f])\left(\begin{array}{cc}
0 & \frac{1}{2}\\
\frac{1}{2} & 0
\end{array}\right)+\left(\begin{array}{cc}
W[e,f] & 0\\
0 & W[g,h]
\end{array}\right)
\]

\end_inset


\begin_inset Formula 
\[
\left(\begin{array}{cc}
a & b\\
c & d
\end{array}\right)\left(\begin{array}{cc}
e & f\\
g & h
\end{array}\right)\left(\begin{array}{cc}
0 & \frac{\mathcal{W}}{2}\\
\frac{\mathcal{W}^{T}}{2} & 0
\end{array}\right)\left(\begin{array}{cc}
e & g\\
f & h
\end{array}\right)\left(\begin{array}{cc}
a & c\\
b & d
\end{array}\right)=\left(\begin{array}{cc}
ae+bg & af+bh\\
ce+dg & cf+dh
\end{array}\right)\left(\begin{array}{cc}
0 & \frac{\mathcal{W}}{2}\\
\frac{\mathcal{W}^{T}}{2} & 0
\end{array}\right)\left(\begin{array}{cc}
ae+bg & ce+dg\\
af+bh & cf+dh
\end{array}\right)
\]

\end_inset


\begin_inset Formula 
\begin{eqnarray*}
W[cf+dh,ae+bg] & = & (cf+dh)(ae+bg)^{\prime}-(cf+dh)^{\prime}(ae+bg)\\
 & = & (cf+dh)(a^{\prime}e+ae^{\prime}+b^{\prime}g+bg^{\prime})-(c^{\prime}f+cf^{\prime}+d^{\prime}h+dh^{\prime})(ae+bg)
\end{eqnarray*}

\end_inset


\begin_inset Formula 
\begin{eqnarray*}
W[ce+dg,af+bh] & = & (ce+dg)(af+bh)^{\prime}-(ce+dg)^{\prime}(af+bh)\\
 & = & (ce+dg)(a^{\prime}f+af^{\prime}+b^{\prime}h+bh^{\prime})-(c^{\prime}e+ce^{\prime}+d^{\prime}g+dg^{\prime})(af+bh)
\end{eqnarray*}

\end_inset


\begin_inset Formula 
\begin{eqnarray*}
W[ce+dg,af+bh]-W[cf+dh,ae+bg] & = & (ce+dg)(a^{\prime}f+af^{\prime}+b^{\prime}h+bh^{\prime})-(cf+dh)(a^{\prime}e+ae^{\prime}+b^{\prime}g+bg^{\prime})\\
 &  & -(c^{\prime}e+ce^{\prime}+d^{\prime}g+dg^{\prime})(af+bh)+(c^{\prime}f+cf^{\prime}+d^{\prime}h+dh^{\prime})(ae+bg)\\
 & = & (ce+dg)(af^{\prime}+bh^{\prime})+ceb^{\prime}h+dga^{\prime}f-(cf+dh)(ae^{\prime}+bg^{\prime})-cfb^{\prime}g-dha^{\prime}e\\
 &  & -(ce^{\prime}+dg^{\prime})(af+bh)-d^{\prime}gaf-c^{\prime}ebh+(cf^{\prime}+dh^{\prime})(ae+bg)+d^{\prime}hae+c^{\prime}fbg\\
 & = & (ceaf^{\prime}+dgaf^{\prime}+cebh^{\prime}+dgbh^{\prime})+cb^{\prime}\Delta_{2}-(cfae^{\prime}+dhae^{\prime}+cfbg^{\prime}+dhbg^{\prime})-da^{\prime}\Delta_{2}\\
 &  & -(ce^{\prime}af+dg^{\prime}af+ce^{\prime}bh+dg^{\prime}bh)-c^{\prime}b\Delta_{2}+(cf^{\prime}ae+dh^{\prime}ae+cf^{\prime}bg+dh^{\prime}bg)+d^{\prime}a\Delta_{2}\\
 & = & (2ceaf^{\prime}+daW[g,f]+cbW[e,h]+2dgbh^{\prime})-(2cfae^{\prime}+daW[h,e]+cbW[f,g]+2dhbg^{\prime})\\
 &  & +cb^{\prime}\Delta_{2}-da^{\prime}\Delta_{2}-c^{\prime}b\Delta_{2}+d^{\prime}a\Delta_{2}\\
 & = & 2caW[e,f]+2dbW[g,h]+(cb+da)(W[e,h]-W[f,g])+\Delta_{2}(W[c,b]-W[d,a])
\end{eqnarray*}

\end_inset


